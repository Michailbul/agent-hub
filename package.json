{
  "name": "@laniameda/agent-hub",
  "version": "0.2.0",
  "main": "dist/server.js",
  "dependencies": {
    "cookie-parser": "^1.4.6",
    "express": "^4.18.2",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "bin": {
    "agent-hub": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts src/server.ts --format cjs --target node18 --clean",
    "dev": "tsup src/cli.ts src/server.ts --format cjs --target node18 --watch",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "description": "Self-hosted web editor for AI agent workspaces \u2014 SOUL.md, skills, MEMORY.md and more",
  "license": "MIT",
  "keywords": [
    "ai",
    "agents",
    "claude",
    "openai",
    "codex",
    "openclaw",
    "editor",
    "self-hosted"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Michailbul/agent-hub"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/",
    "index.html",
    "README.md",
    "agent-hub.config.example.json",
    "docker-compose.example.yml"
  ]
}